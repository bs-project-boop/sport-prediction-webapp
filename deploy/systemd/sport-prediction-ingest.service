[Unit]
Description=Sport Prediction — Ingest latest JSON reports
After=network.target postgresql.service

[Service]
Type=oneshot
User=sportapp
WorkingDirectory=/opt/sport-prediction/current/backend
EnvironmentFile=/etc/sport-prediction/app.env
ExecStart=/opt/sport-prediction/current/backend/venv/bin/python -m app.workers.ingest --root /Users/beem/.hermes-shared/reports/sports/v3 --date today
